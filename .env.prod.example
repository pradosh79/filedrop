# ════════════════════════════════════════════════════════════
# Custom File Upload Pro — Production Environment
# NO AWS REQUIRED
#
# Copy to .env.prod, fill in all values, never commit to git.
# ════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=https://your-domain.com
APP_DOMAIN=your-domain.com

# ── Shopify ──────────────────────────────────────────────────
# Get from: partners.shopify.com → Apps → Your App → API credentials
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_products,write_products,read_orders,write_orders,read_customers,write_script_tags,read_themes,write_themes

# ── Database ─────────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=cfup_user
DB_PASSWORD=CHANGE_THIS_STRONG_DB_PASSWORD
DB_DATABASE=cfup_db
DB_ROOT_PASSWORD=CHANGE_THIS_STRONG_ROOT_PASSWORD
DB_SSL=false

# ── JWT ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=24h

# ── File Storage (choose ONE option below) ───────────────────

# OPTION A: MinIO — self-hosted, bundled in docker-compose (FREE, recommended)
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=cfup_minio
MINIO_ROOT_PASSWORD=CHANGE_THIS_MINIO_PASSWORD
MINIO_BUCKET=cfup-uploads

# OPTION B: Cloudflare R2 — FREE 10GB, no egress fees
# Create at: dash.cloudflare.com → R2 → Create bucket
# STORAGE_PROVIDER=r2
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key
# R2_SECRET_ACCESS_KEY=your_r2_secret_key
# R2_BUCKET=cfup-uploads
# R2_PUBLIC_URL=https://pub-xxx.r2.dev   # optional public domain

# OPTION C: AWS S3 — if client already has AWS
# STORAGE_PROVIDER=s3
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_S3_BUCKET=cfup-uploads

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://:cfup_redis_pass@redis:6379
REDIS_PASSWORD=cfup_redis_pass

# ── ClamAV ───────────────────────────────────────────────────
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# ── Email (choose a FREE SMTP provider) ──────────────────────
# Option A: Resend (3,000 emails/month free) — https://resend.com
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_USER=resend
#   SMTP_PASS=re_your_api_key

# Option B: Brevo (300 emails/day free) — https://brevo.com
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USER=your@email.com
#   SMTP_PASS=your_brevo_smtp_key

# Option C: SendGrid (100 emails/day free) — https://sendgrid.com
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=SG.your_sendgrid_api_key

# Option D: Gmail (500/day, personal use only)
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your@gmail.com
#   SMTP_PASS=your_gmail_app_password   # not your real password, use App Password

SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_YOUR_RESEND_API_KEY
EMAIL_FROM=noreply@your-domain.com

# ── Billing ──────────────────────────────────────────────────
BILLING_RETURN_URL=https://your-domain.com/billing/activate

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
