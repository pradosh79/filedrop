# ════════════════════════════════════════════════════════════════
# Filedrop — Backend environment variables
# Copy to .env for local development, .env.prod for production
# ════════════════════════════════════════════════════════════════

NODE_ENV=development
PORT=3000
APP_URL=https://YOUR_NGROK_URL.ngrok.io

# ── Shopify (from partners.shopify.com) ───────────────────────
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_products,read_orders,write_orders,read_customers,write_metafields,read_metafields
# Set to "true" to mark Shopify app subscription charges as test charges
# (no real money moves). Always leave unset/"false" in production.
SHOPIFY_BILLING_TEST_MODE=false

# ── Database (MySQL 8) ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=cfup_user
DB_PASSWORD=cfup_password
DB_NAME=cfup_db
DB_SSL=false

# ── JWT ────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-random-64-char-string-before-production

# ── File storage — MinIO (self-hosted, S3-compatible) ─────────
# MinIO runs locally. For production it runs on the same VPS.
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=cfup_minio
MINIO_ROOT_PASSWORD=cfup_secret_change_in_prod
MINIO_BUCKET=cfup-uploads
MINIO_REGION=us-east-1

# ── Virus scanning (ClamAV) ───────────────────────────────────
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# ── Email (SMTP) ───────────────────────────────────────────────
# Dev: use Mailpit (brew install mailpit) — UI at http://localhost:8025
# Prod: use Resend (free 3,000/mo), Brevo, or any SMTP provider
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourapp.com

# ── App URLs ───────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BILLING_RETURN_URL=https://YOUR_NGROK_URL.ngrok.io/billing/activate

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Virus scanning — VirusTotal (optional, free 500 scans/day) ─
# Get free API key at virustotal.com → Sign up → API Key
# Leave blank to use basic hash-based scanning instead
VIRUSTOTAL_API_KEY=

# ── Storage: Cloudflare R2 (alternative to MinIO, free 10GB) ──
# Set STORAGE_PROVIDER=r2 and fill these to use R2 instead of MinIO
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_key_id
# R2_SECRET_ACCESS_KEY=your_r2_secret_key
# R2_BUCKET=cfup-uploads
