# ════════════════════════════════════════════════════════════════
# Filedrop — PRODUCTION environment variables
# Place this file on your VPS as .env.prod in the project root
# ════════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=3000
APP_DOMAIN=yourdomain.com
APP_URL=https://yourdomain.com

# ── Shopify ────────────────────────────────────────────────────
SHOPIFY_API_KEY=CHANGE_THIS
SHOPIFY_API_SECRET=CHANGE_THIS
SHOPIFY_SCOPES=read_products,read_orders,write_orders,read_customers,write_metafields,read_metafields

# ── Database ───────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=cfup_user
DB_PASSWORD=CHANGE_THIS_strong_password
DB_NAME=cfup_db
DB_SSL=false

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_run_node_-e_console.log(require('crypto').randomBytes(64).toString('hex'))

# ── MinIO file storage (runs on same VPS) ─────────────────────
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=cfup_minio
MINIO_ROOT_PASSWORD=CHANGE_THIS_strong_password
MINIO_BUCKET=cfup-uploads
MINIO_REGION=us-east-1

# ── Virus scanning ─────────────────────────────────────────────
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# ── Email (use Resend free tier: resend.com) ──────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=CHANGE_THIS_resend_api_key
EMAIL_FROM=noreply@yourdomain.com

# ── App ────────────────────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com
BILLING_RETURN_URL=https://yourdomain.com/billing/activate
LOG_LEVEL=warn

# ── Virus scanning (optional) ─────────────────────────────────
VIRUSTOTAL_API_KEY=CHANGE_THIS_or_leave_blank

# ── Cloudflare R2 storage (recommended over MinIO for production)
# STORAGE_PROVIDER=r2
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_key_id
# R2_SECRET_ACCESS_KEY=your_r2_secret_key
# R2_BUCKET=cfup-uploads
