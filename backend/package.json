{
  "name": "cfup-backend",
  "version": "1.0.0",
  "description": "Custom File Upload Pro \u2014 NestJS backend (no AWS required)",
  "scripts": {
    "build": "npx nest build",
    "start": "node dist/main",
    "start:dev": "npx nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli",
    "migration:run": "npm run typeorm migration:run -- -d src/common/config/database.config.ts",
    "migration:revert": "npm run typeorm migration:revert -- -d src/common/config/database.config.ts",
    "migration:generate": "npm run typeorm migration:generate -- -d src/common/config/database.config.ts",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/config": "^3.1.1",
    "@nestjs/typeorm": "^10.0.1",
    "@nestjs/throttler": "^5.1.1",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/axios": "^3.0.2",
    "typeorm": "^0.3.19",
    "mysql2": "^3.7.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "jsonwebtoken": "^9.0.2",
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.500.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.8",
    "nest-winston": "^1.9.4",
    "winston": "^3.11.0",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "helmet": "^7.1.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.0",
    "axios": "^1.6.0",
    "@nestjs/cli": "^10.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "tsconfig-paths": "^4.2.0",
    "@nestjs/schematics": "^10.1.0",
    "@types/node": "^20.11.5",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/passport-jwt": "^4.0.1",
    "@types/nodemailer": "^6.4.14",
    "@types/uuid": "^9.0.7",
    "@types/nock": "^11.1.0",
    "@nestjs/testing": "^10.3.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "@golevelup/ts-jest": "^0.4.0",
    "supertest": "^6.3.4",
    "@swc/core": "^1.4.0",
    "@swc/cli": "^0.3.0",
    "nock": "^13.4.0"
  },
  "devDependencies": {},
  "config": {}
}